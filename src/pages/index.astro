---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getPublishedPosts, SERIES_META, SITE_DESCRIPTION, SITE_TITLE, ENGINEERING_TAGS } from '../consts';

const posts = await getPublishedPosts();

const personalPosts = posts.filter((post) => {
	if (post.data.series) {
		const meta = SERIES_META[post.data.series];
		return meta && meta.category === 'blog';
	}
	const isEngineering = post.data.tags.some((tag) => ENGINEERING_TAGS.has(tag));
	return !isEngineering;
}).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const highlightedPersonalPosts = personalPosts.slice(0, 9);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": SITE_TITLE,
			"url": "https://d3banjan.github.io/",
			"description": SITE_DESCRIPTION,
			"publisher": {
				"@type": "Person",
				"name": "Debanjan Basu",
				"url": "https://d3banjan.github.io/",
				"sameAs": [
					"https://linkedin.com/in/debanjan-basu",
					"https://github.com/d3banjan"
				]
			},
			"hasPart": [
				{
					"@type": "WebPage",
					"@id": "https://d3banjan.github.io/research/",
					"name": "Research Hub",
					"url": "https://d3banjan.github.io/research/",
					"description": "ML compression with Lean 4 formal bounds, LoRA alignment geometry, and falsifiable empirical methodology."
				},
				{
					"@type": "WebPage",
					"@id": "https://d3banjan.github.io/engineering/",
					"name": "Engineering Hub",
					"url": "https://d3banjan.github.io/engineering/",
					"description": "Production systems, distributed pipelines, task queues, and LLM agent infrastructure."
				},
				{
					"@type": "WebPage",
					"@id": "https://d3banjan.github.io/blog/",
					"name": "Personal Curiosity Blog",
					"url": "https://d3banjan.github.io/blog/",
					"description": "Personal blog including Bengali deep history, Berlin transit crisis, and general thoughts."
				}
			]
		})} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.tagline {
				font-style: italic;
				color: var(--accent);
				font-size: 1.1em;
				margin-bottom: 0.5em;
			}
			.location {
				color: rgb(var(--gray));
				margin-bottom: 2em;
			}
			section {
				margin-bottom: 2.5em;
			}
			h2 {
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.3em;
				margin-bottom: 1em;
			}
			.start-here-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1em;
			}
			.start-here-item {
				padding: 1em 1.1em;
				background: rgba(var(--gray-light), 0.12);
				border-left: 3px solid var(--accent);
				border-radius: 0 6px 6px 0;
			}
			.start-here-item p {
				margin: 0;
			}
			.start-here-kicker {
				color: var(--accent);
				font-size: 0.75em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			.start-here-title {
				display: block;
				margin: 0.25em 0 0.35em;
				color: rgb(var(--black));
				font-weight: 700;
				text-decoration: none;
			}
			.start-here-title:hover {
				color: var(--accent);
			}
			.start-here-desc {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}

			/* ── Explore Hubs ── */
			.explore-hubs {
				margin: 3em 0;
			}
			.hubs-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.5rem;
				margin-top: 1em;
			}
			.hub-card {
				padding: 1.5em;
				background: rgba(var(--gray-light), 0.15);
				border-radius: 8px;
				text-decoration: none;
				display: flex;
				flex-direction: column;
				transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
				border: 1px solid rgba(var(--gray-light), 0.5);
			}
			.hub-card:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
			}
			.hub-card.research {
				border-top: 4px solid #0d9488;
			}
			@media (prefers-color-scheme: dark) {
				.hub-card.research {
					border-top-color: #2dd4bf;
				}
			}
			.hub-card.engineering {
				border-top: 4px solid #d97706;
			}
			@media (prefers-color-scheme: dark) {
				.hub-card.engineering {
					border-top-color: #fbbf24;
				}
			}
			.hub-card.personal {
				border-top: 4px solid #4f46e5;
			}
			@media (prefers-color-scheme: dark) {
				.hub-card.personal {
					border-top-color: #818cf8;
				}
			}
			.hub-kicker {
				font-size: 0.72em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: 0.4em;
			}
			.hub-card.research .hub-kicker {
				color: #0d9488;
			}
			@media (prefers-color-scheme: dark) {
				.hub-card.research .hub-kicker {
					color: #2dd4bf;
				}
			}
			.hub-card.engineering .hub-kicker {
				color: #d97706;
			}
			@media (prefers-color-scheme: dark) {
				.hub-card.engineering .hub-kicker {
					color: #fbbf24;
				}
			}
			.hub-card.personal .hub-kicker {
				color: #4f46e5;
			}
			@media (prefers-color-scheme: dark) {
				.hub-card.personal .hub-kicker {
					color: #818cf8;
				}
			}
			.hub-card h3 {
				font-size: 1.25em;
				margin: 0 0 0.5em 0;
				color: rgb(var(--black));
			}
			.hub-card p {
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
				margin: 0;
				line-height: 1.5;
			}

			/* ── Curated Personal Grid ── */
			.personal-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5rem;
				margin: 2em 0;
			}
			@media (max-width: 768px) {
				.personal-grid {
					grid-template-columns: 1fr;
				}
			}
			.post-card {
				background: rgba(var(--gray-light), 0.1);
				border-radius: 8px;
				padding: 1.5em;
				text-decoration: none;
				display: flex;
				flex-direction: column;
				color: inherit;
				transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
				border: 1px solid rgba(var(--gray-light), 0.3);
			}
			.post-card:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
				border-color: var(--accent);
			}
			.post-card.prominent {
				background: rgba(var(--accent-rgb), 0.04);
				border-top: 4px solid var(--accent);
			}
			.post-card.prominent h3 {
				font-size: 1.25em;
				margin: 0.3em 0;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.post-card.normal {
				border-left: 3px solid rgba(var(--gray-light), 0.8);
				padding: 1.2em;
			}
			.post-card.normal h3 {
				font-size: 1.1em;
				margin: 0.2em 0;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.post-card .date {
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.post-card .desc {
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
				margin: 0.5em 0 1em;
				flex-grow: 1;
			}
			.card-footer {
				margin-top: auto;
				display: flex;
				align-items: center;
				justify-content: flex-end;
			}
			.series-tag {
				font-size: 0.72em;
				font-weight: 700;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				color: var(--accent);
				background: rgba(var(--accent-rgb), 0.08);
				padding: 0.2em 0.6em;
				border-radius: 4px;
			}
			.see-all-container {
				text-align: center;
				margin-top: 2.5em;
			}
			.see-all-btn {
				display: inline-block;
				padding: 0.6em 1.8em;
				background: var(--accent);
				color: white !important;
				font-weight: 600;
				border-radius: 6px;
				text-decoration: none;
				transition: transform 0.2s ease, opacity 0.2s ease;
			}
			.see-all-btn:hover {
				opacity: 0.9;
				transform: translateY(-1px);
			}

			/* CTA */
			.cta {
				margin-top: 2em;
			}
			.cta a {
				display: inline-block;
				background: var(--accent);
				color: white;
				padding: 0.6em 1.5em;
				border-radius: 4px;
				text-decoration: none;
				margin-right: 1em;
				margin-bottom: 0.5em;
			}
			.cta a:hover {
				opacity: 0.9;
			}
			.cta a.secondary {
				background: transparent;
				border: 1px solid var(--accent);
				color: var(--accent);
			}
			.contact-link {
				color: var(--accent);
			}
		</style>
	</head>
	<body class="theme-home">
		<Header />
		<main>
			<h1>Debanjan Basu</h1>
			<p class="tagline">Research Engineer / ML Systems Engineer · LLM Infrastructure · Observability</p>

			<p class="location">Berlin, Germany</p>

			<section>
				<p>
					ML systems engineer with independent research bridging post-training methods, formal
					verification, and empirical methodology for safety-relevant claims. LoRA-DPO scaling
					work on Pythia 70M–1B documents geometry–behaviour decoupling: γ-overlap doesn't
					predict reward margin, suggesting behavioral interventions don't necessarily reorganize
					underlying representations — a structural finding with implications for evaluating
					alignment techniques. Lean 4 invariants formalize the empirical scaling (74 theorems
					across two papers, all in Mathlib).
				</p>
				<p>
					Six years production ML engineering at Nexern: LLM agent observability with Arize
					Phoenix, distributed pipelines, deployment infrastructure. Physics background (IISER
					Kolkata BS-MS; doctoral research under Peter Blöchl at TU Clausthal). Pre-registered
					adversarial validation methodology — trap-cell design, kill-fast sequential testing —
					formalized as the <a href="https://compression-ladder-paper.pages.dev/">Compression Falsification Ladder</a>.
				</p>
			</section>

			<section class="explore-hubs">
				<h2>Explore the Hubs</h2>
				<div class="hubs-grid">
					<a href="/research/" class="hub-card research">
						<span class="hub-kicker">Research Hub</span>
						<h3>ML & Theory</h3>
						<p>ML compression, LLM agent systems, Lean 4, and falsifiable empirical methodology.</p>
					</a>
					<a href="/engineering/" class="hub-card engineering">
						<span class="hub-kicker">Engineering Hub</span>
						<h3>Systems & Infra</h3>
						<p>Production Python, Django, developer tooling, security gates, and Linux workflow.</p>
					</a>
					<a href="/blog/" class="hub-card personal">
						<span class="hub-kicker">Personal Curiosity</span>
						<h3>Chronological Blog</h3>
						<p>Bengali history, Berlin transit, working notes, and thoughts that do not need a narrower shelf.</p>
					</a>
				</div>
			</section>

			<section>
				<h2>Start here</h2>
				<div class="start-here-grid">
					<div class="start-here-item">
						<p class="start-here-kicker">Paper artifact</p>
						<a class="start-here-title" href="https://moe-gauge-paper.pages.dev/">
							Phase-Collapse Defragmentation
						</a>
						<p class="start-here-desc">
							Moment-ratio bounds, MoE KV-cache quantization, and zero-sorry Lean source.
						</p>
					</div>
					<div class="start-here-item">
						<p class="start-here-kicker">Methodology</p>
						<a class="start-here-title" href="https://compression-ladder-paper.pages.dev/">
							The Compression Falsification Ladder
						</a>
						<p class="start-here-desc">
							Pre-registration, τ-baselines, trap cells, and kill-fast empirical design.
						</p>
					</div>
					<div class="start-here-item">
						<p class="start-here-kicker">Negative results</p>
						<a class="start-here-title" href="/blog/2026-04-22-lora-adversarial-passes/">
							Adversarial Passes That Retracted Two Claims
						</a>
						<p class="start-here-desc">
							What survived when the LoRA-DPO geometry story was forced to attack itself.
						</p>
					</div>
				</div>
			</section>

			<section>
				<h2>Curated Personal Writings</h2>
				<div class="personal-grid">
					{highlightedPersonalPosts.map((post, i) => {
						const isProminent = i < 3;
						return (
							<a href={`/blog/${post.id}/`} class={`post-card ${isProminent ? 'prominent' : 'normal'}`}>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<h3>{post.data.title}</h3>
								<p class="desc">{post.data.description}</p>
								<div class="card-footer">
									{post.data.series && (
										<span class="series-tag">{post.data.series}</span>
									)}
								</div>
							</a>
						);
					})}
				</div>
				<div class="see-all-container">
					<a href="/blog/" class="see-all-btn">See all personal writings &rarr;</a>
				</div>
			</section>

			<section>
				<h2>Get in Touch</h2>
				<p>
					I'm always interested in conversations about AI systems, physics-informed machine learning,
					or elegant solutions to hard problems.
				</p>
				<p><a class="contact-link" href="mailto:debanjan.basu.ds@gmail.com">debanjan.basu.ds@gmail.com</a></p>
			</section>

			<div class="cta">
				<a href="/blog/">Read the Blog</a>
				<a href="/cv-engineering.pdf" class="secondary" target="_blank">CV (Engineering)</a>
				<a href="/about/" class="secondary">About</a>
			</div>
		</main>
		<Footer />


	</body>
</html>
