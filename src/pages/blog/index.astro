---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import TagList from '../../components/TagList.astro';
import { getPublishedPosts, SERIES_META, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getPublishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Map each series name to its sorted posts (oldest to newest)
const seriesPostsMap = new Map<string, typeof posts>();
for (const p of posts) {
	if (p.data.series) {
		const list = seriesPostsMap.get(p.data.series) ?? [];
		list.push(p);
		seriesPostsMap.set(p.data.series, list);
	}
}

for (const [, list] of seriesPostsMap.entries()) {
	list.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.landing-intro {
				max-width: 720px;
				margin-bottom: 2em;
			}
			.category-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1em;
				margin: 1.5em 0 2.5em;
			}
			.category-card {
				padding: 1em;
				border-left: 3px solid var(--accent);
				background: rgba(var(--gray-light), 0.15);
				border-radius: 0 6px 6px 0;
				text-decoration: none;
				color: rgb(var(--black));
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.category-card:hover {
				transform: translateY(-1px);
				box-shadow: var(--box-shadow);
			}
			.category-card h2 {
				font-size: 1.1em;
				margin: 0 0 0.3em;
			}
			.category-card p {
				font-size: 0.9em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.archive-heading {
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.3em;
				margin: 0 0 1.5em;
			}
		</style>
	</head>
	<body class="theme-home">
		<Header />
		<main>
			<section class="landing-intro">
				<h1>Blog</h1>
				<p>
					Everything in reverse chronological order: research notes, engineering writeups,
					Bengali history, Berlin transit, and working notes that do not need a narrower shelf.
				</p>
			</section>
			<nav class="category-grid" aria-label="Writing categories">
				<a class="category-card" href="/research/">
					<h2>Research</h2>
					<p>ML compression, LLM agent systems, Lean 4, and falsifiable empirical methodology.</p>
				</a>
				<a class="category-card" href="/engineering/">
					<h2>Engineering</h2>
					<p>Production Python, Django, developer tooling, security gates, and Linux workflow.</p>
				</a>
			</nav>
			<section>
				<h2 class="archive-heading">All posts</h2>
				<div class="timeline-container">
					<div class="timeline-spine"></div>
					<div class="timeline-feed">
						{
							posts.map((post, i) => {
								const hasSeries = post.data.series && SERIES_META[post.data.series];
								const seriesMeta = hasSeries ? SERIES_META[post.data.series!] : null;
								
								// Calculate series progression
								let indexInSeries = 0;
								let totalInSeries = 0;
								if (hasSeries) {
									const list = seriesPostsMap.get(post.data.series!);
									indexInSeries = list ? list.findIndex((p) => p.id === post.id) + 1 : 0;
									totalInSeries = list ? list.length : 0;
								}

								// Check if consecutive posts in timeline are in same series to connect them
								const currentSeries = post.data.series;
								const nextInSameSeries = currentSeries && i < posts.length - 1 && posts[i + 1].data.series === currentSeries;
								
								// Determine side and theme classes
								const isSeries = !!seriesMeta;
								const itemClass = isSeries ? 'series' : 'single';
								const categoryClass = seriesMeta 
									? (seriesMeta.category === 'blog' ? 'home' : seriesMeta.category)
									: 'home';
								
								return (
									<div class={`timeline-item ${itemClass} theme-${categoryClass}`}>
										<div class="timeline-node"></div>
										<div class="timeline-card-wrapper">
											{nextInSameSeries && <div class="series-connection"></div>}
											<div class="timeline-card">
												{isSeries && (
													<div class="series-progression">
														Series · Post {indexInSeries}/{totalInSeries}
													</div>
												)}
												<h4 class="title">
													<a href={`/blog/${post.id}/`} class="title-link">
														{post.data.title}
													</a>
												</h4>
												<p class="date">
													<FormattedDate date={post.data.pubDate} />
												</p>
												<p class="description">
													{post.data.description}
												</p>
												<div class="post-tags">
													<TagList tags={post.data.tags} />
												</div>
											</div>
										</div>
									</div>
								);
							})
						}
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
